{
  "$schema": "https://mintlify.com/docs.json",
  "name": "NeetoPlaydash API",
  "description": "NeetoPlaydash API docs guide to manage runs from external channels",
  "theme": "mint",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "logo": "/assets/logo.svg",
  "favicon": "/assets/favicon.ico",
  "navbar": {
    "links": [
      {
        "label": "Blog",
        "href": "https://www.neeto.com/neetoplaydash/blog"
      },
      {
        "label": "Help Center",
        "href": "https://help.neetoplaydash.com"
      },
      {
        "label": "NeetoPlaydash",
        "href": "https://neetoplaydash.com/"
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/neetohq",
      "linkedin": "https://www.linkedin.com/company/neeto",
      "youtube": "https://www.youtube.com/channel/UCoQ3Kv2JdZ51WZJ3QFFcI9g",
      "slack": "https://www.launchpass.com/neetohq"
    }
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting Started",
        "icon": "rocket",
        "pages": [
          "getting-started/introduction",
          "getting-started/workspace-subdomain",
          "getting-started/authentication",
          "getting-started/pagination",
          "getting-started/response-codes"
        ]
      },
      {
        "group": "Projects",
        "icon": "folder",
        "pages": [
          "api-reference/projects/list"
        ]
      },
      {
        "group": "Runs",
        "icon": "play",
        "pages": [
          "api-reference/runs/list",
          "api-reference/runs/get"
        ]
      },
      {
        "group": "Test Entities",
        "icon": "vial",
        "pages": [
          "api-reference/test-entities/list",
          "api-reference/test-entities/get"
        ]
      },
      {
        "group": "Result Histories",
        "icon": "clock-rotate-left",
        "pages": [
          "api-reference/result-histories/list"
        ]
      },
      {
        "group": "Traces",
        "icon": "route",
        "pages": [
          "api-reference/traces/list"
        ]
      }
    ]
  },
  "api": {
    "params": {
      "expanded": "all"
    },
    "playground": {
      "display": "interactive",
      "proxy": true
    },
    "examples": {
      "languages": ["curl", "javascript", "python"],
      "defaults": "all"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "system"
  },
  "appearance": {
    "default": "light",
    "strict": true
  }
}
